{
  "name": "order-service",
  "version": "1.0.0",
  "description": "E-commerce Order Management Service",
  "main": "dist/infrastructure/http/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/infrastructure/http/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/infrastructure/http/server.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern='tests/unit' --runInBand",
    "test:integration": "jest --testPathPattern='tests/integration' --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:ci": "jest --coverage --runInBand --forceExit"
  },
  "keywords": [
    "ecommerce",
    "orders",
    "fastify",
    "mongodb",
    "rabbitmq"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "amqplib": "^0.10.4",
    "fastify": "^4.28.1",
    "mongoose": "^8.4.1",
    "pino": "^9.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}

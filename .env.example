# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVICE_NAME=order-service
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local dev (docker-compose):
MONGO_URI=mongodb://localhost:27017/orders

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose):
RABBITMQ_URL=amqp://guest:guest@localhost:5672
